    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "plop": "^4.0.0",
    "tsx": "^4.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
