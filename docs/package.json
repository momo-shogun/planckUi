{
  "name": "@planckui/docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate:sources": "node scripts/sync-bottom-tabs-lab-sources.mjs",
    "predev": "pnpm run generate:sources",
    "prebuild": "pnpm run generate:sources",
    "dev": "next dev -p 3001",
    "dev:fresh": "pnpm run clean && pnpm run dev",
    "build": "next build",
    "start": "next start -p 3001",
