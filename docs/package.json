    "clean": "rm -rf .next out"
  },
  "dependencies": {
    "@my-ui-lib/core": "workspace:*",
    "@my-ui-lib/tokens": "workspace:*",
    "next": "^14.2.0",
    "nextra": "^2.13.0",
    "nextra-theme-docs": "^2.13.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-native": "npm:react-native-web@^0.19.0",
    "react-native-web": "^0.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.4.0"
  }
}
